{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Idou Studio",
  "version": "0.1.0",
  "identifier": "com.idou.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Idou Studio",
        "width": 1600,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
